{
  "files.exclude": {
    "**/.git": true,
    "**/.next": true,
    "**/node_modules": true
  },
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,
  "explorer.fileNesting.patterns": {
    "package.json": "package-lock.json, tsconfig.json, next.config.mjs, tailwind.config.ts, next-env.d.ts, .env, .gitignore"
  }
}
